# AcadMix Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# RECOMMENDED: Use Doppler instead of this file for secrets management.
# Run: doppler run -- python server.py
# This file is a fallback for environments without Doppler.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
JWT_SECRET=<generate-a-strong-random-secret-here>
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000

# ── Security (REQUIRED) ──────────────────────────────────────────────────────
ADMIN_PASSWORD=<set-a-strong-admin-password>
# SEED_DEMO_USERS=true              # ONLY set in dev/staging
# DEBUG_MODE=true                    # ONLY set in dev/staging

# ── External Integrations ─────────────────────────────────────────────────────
VERTEX_PROJECT_ID=acadmix-production-123
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS_JSON=  # Optional: For Render / Ephemeral
VERTEX_CREDENTIALS_PATH=              # Optional: For local dev (e.g. ./secrets/gcp.json)
GEMINI_API_KEY=
SENTRY_DSN=
CODE_RUNNER_URL=https://acadmix-code-runner.fly.dev
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=acadmix-interview-agent
INTERVIEW_TTS_PROVIDER=cartesia  # cartesia | deepgram | google
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_WEBHOOK_SECRET=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_MOCK_MODE=true

# ── IoT ───────────────────────────────────────────────────────────────────────
IOT_WEBHOOK_SECRET=

# ── Payments ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Datadog APM (Observability) ───────────────────────────────────────────────
DD_API_KEY=                            # Datadog API key
DD_SITE=us5.datadoghq.com             # Datadog site (us5, eu, etc.)
DD_SERVICE=acadmix-api                 # Service name in APM dashboard
DD_ENV=development                     # development | staging | production
DD_VERSION=2.0.0                       # Application version
DD_TRACE_ENABLED=true                  # Set false to disable tracing

# ── Deployment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development                    # development | staging | production
# WEB_CONCURRENCY=4                       # Gunicorn workers (default: 2*CPU+1)
# PORT=8000                               # API port
# LOG_LEVEL=info                           # Python log level
